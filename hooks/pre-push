#!/usr/bin/env bash
# pre-push — 每次 push 前對「即將推出的 commit range」跑 /code-review xhigh,FAIL 則擋下。
# git 以 stdin 傳入:<local ref> <local sha> <remote ref> <remote sha> (每個要推的 ref 一行)
set -uo pipefail
source "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/lib-review.sh"

ZERO=0000000000000000000000000000000000000000

while read -r local_ref local_sha remote_ref remote_sha; do
  # 刪除遠端分支:沒有東西可審
  [ "$local_sha" = "$ZERO" ] && continue

  if [ "$remote_sha" = "$ZERO" ]; then
    # 新分支:以與 origin/HEAD 的分岔點為基準;找不到就只審最後一個 commit
    base=$(git merge-base "$local_sha" "$(git rev-parse --abbrev-ref origin/HEAD 2>/dev/null || echo "$local_sha~1")" 2>/dev/null) \
      || base=$(git rev-parse "$local_sha~1" 2>/dev/null) || continue
  else
    base="$remote_sha"
  fi

  # range 內沒有實際差異就跳過
  git diff --quiet "$base" "$local_sha" 2>/dev/null && continue

  n=$(git rev-list --count "$base..$local_sha" 2>/dev/null || echo "?")
  echo "📤 pre-push:$remote_ref ← $n 個 commit ($(git rev-parse --short "$base")..$(git rev-parse --short "$local_sha"))"

  if ! review_gate "本次審查即將推送的 commit range:git diff $base $local_sha(commit 列表見 git log $base..$local_sha)。working tree 的其他變更一律忽略"; then
    echo "❌ code review 未通過 — push 已擋下。"
    echo "   修正後重試;或 SKIP_REVIEW=1 git push …/ git push --no-verify 強行通過。"
    exit 1
  fi
done < /dev/stdin

run_repo_hook pre-push "$@"
